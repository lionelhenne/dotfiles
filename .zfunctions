# ------------------------------------------------------------
# Common library
# ------------------------------------------------------------
[[ -f "$HOME/.local/lib/_common.sh" ]] && source "$HOME/.local/lib/_common.sh"

# ------------------------------------------------------------
# Package management
# ------------------------------------------------------------
update() {
    log_header "CHECKING FOR UPDATES"
    log_info "COMPOSER GLOBAL"
    composer global outdated
    echo
    log_info "HOMEBREW"
    brew update --quiet && brew outdated --formula
    echo
    log_info "NPM GLOBAL"
    npm outdated -g
}

upgrade() {
    log_header "UPGRADING PACKAGES"
    log_info "HOMEBREW FORMULAS"
    brew upgrade --formula
    echo
    log_info "COMPOSER GLOBAL"
    composer global update
    echo
    log_info "NPM GLOBAL"
    npm update -g
    echo
    log_info "HOMEBREW CLEANUP"
    brew cleanup
    echo
    log_success "ALL PACKAGES UPGRADED"
}

list() {
    log_header "COMPOSER GLOBAL"
    composer global show --direct | sort

    log_header "HOMEBREW LEAVES"
    brew leaves | sort | pr -4 -t -w $COLUMNS

    log_header "HOMEBREW DEPENDENCIES"
    comm -13 <(brew leaves | sort) <(brew list --formula | sort) | pr -4 -t -w $COLUMNS

    log_header "HOMEBREW CASKS"
    brew list --cask | grep -v "^font-" | sort | pr -4 -t -w $COLUMNS

    log_header "HOMEBREW FONTS"
    brew list --cask | grep "^font-" | pr -4 -t -w $COLUMNS

    log_header "NPM GLOBAL"
    npm list -g --depth=0 --parseable | sed "1d" | xargs -n1 basename | sort | pr -4 -t -w $COLUMNS
}
